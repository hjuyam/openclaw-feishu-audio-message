# Feishu (required)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Optional: default is https://open.feishu.cn
FEISHU_DOMAIN=

# Piper TTS (optional, for text->voice)
# Preferred: install Piper from releases and set PIPER_BIN to the executable path.
PIPER_BIN=
PIPER_VOICE=./models/piper/zh_CN-huayan-x_low.onnx
PIPER_VOICE_CONFIG=./models/piper/zh_CN-huayan-x_low.onnx.json

# Sherpa-ONNX ASR (optional, for voice->text)
SHERPA_ONNX_MODEL_DIR=./models/sherpa/sherpa-onnx-paraformer-zh-small-2024-03-09

# Playback UX tweak: add leading silence before encoding (ms)
FEISHU_VOICE_LEADING_SILENCE_MS=800

# Temp cleanup policy
FEISHU_VOICE_TMP_DIR=./tmp/feishu_voice_mvp
# seconds; default 1800 (30min)
FEISHU_VOICE_FAIL_TTL_SECONDS=1800
